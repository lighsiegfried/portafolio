JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
DYNAMODB_TABLE_PREFIX=mini-erp
DYNAMODB_REGION=us-east-1
NODE_ENV=development
LOG_LEVEL=INFO
DEFAULT_LOW_STOCK_THRESHOLD=5
PORT=3001

# --- Contact Form (Amazon SES) ---
# CONTACT_TO_EMAIL debe ser el correo que recibirás cuando alguien te contacte
# CONTACT_FROM_EMAIL debe ser un email verificado en Amazon SES
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_REPLY_TO_ENABLED=true
SEND_CONTACT_CONFIRMATION=false
SES_REGION=us-east-1
