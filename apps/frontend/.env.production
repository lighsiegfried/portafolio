# Production build config (committed — public, non-secret values only).
# GitHub Actions runs `npm --prefix apps/frontend run build`, which Vite runs in
# production mode and automatically loads this file. A pipeline-provided env var
# of the same name still takes precedence over this value.
# NEVER put AWS keys, session tokens, or presigned (X-Amz-*) URLs here.

# Stable public S3 object URL for the "Mis Finanzas" Android APK (direct download).
VITE_FINANZAS_APK_URL=https://appfinanzas.s3.us-east-1.amazonaws.com/misfinanzas.apk
