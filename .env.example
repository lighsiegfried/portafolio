# ============================================================
# 3D Portafolio — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# ============================================================

# --- EmailJS (Formulario de contacto) ---
VITE_APP_EMAILJS_SERVICE_ID=service_xxxxxx
VITE_APP_EMAILJS_TEMPLATE_ID=template_xxxxxx
VITE_APP_EMAILJS_PUBLIC_KEY=public_key_xxxxxx

# --- API Backend (Mini ERP/CRM Lite - futuro) ---
VITE_API_BASE_URL=https://api.example.com/v1

# --- Backend (Mini ERP/CRM Lite) ---
# DATA_SOURCE = mock | dynamodb
DATA_SOURCE=mock

# --- DynamoDB (solo si DATA_SOURCE=dynamodb) ---
DYNAMODB_TABLE_PREFIX=mini-erp
DYNAMODB_REGION=us-east-1

# --- Entorno ---
# local | development | staging | production
VITE_APP_ENV=local
