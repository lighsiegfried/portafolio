# ============================================================
# 3D Portafolio — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# ============================================================

# --- API Backend (Mini ERP/CRM Lite) ---
VITE_API_BASE_URL=https://api.example.com/v1

# --- Backend (Mini ERP/CRM Lite) ---
# DATA_SOURCE = mock | dynamodb
DATA_SOURCE=mock

# --- DynamoDB (solo si DATA_SOURCE=dynamodb) ---
DYNAMODB_TABLE_PREFIX=mini-erp
DYNAMODB_REGION=us-east-1

# --- Contact Form (Amazon SES - backend) ---
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_REPLY_TO_ENABLED=true
SEND_CONTACT_CONFIRMATION=false
SES_REGION=us-east-1

# --- Entorno ---
# local | development | staging | production
VITE_APP_ENV=local
